{
  "tasks": {
    "dev": "deno run -A --watch scripts/dev.ts",
    "build": "deno run -A scripts/build.ts",
    "check": "deno check scripts src && deno lint && deno fmt --check"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "jsxImportSource": "remix/ui"
  },
  "imports": {
    "remix": "npm:remix@3.0.0-beta.5",
    "@kuboon/remix-ssg": "jsr:@kuboon/remix-ssg@^0.2.0",
    "@kuboon/md": "jsr:@kuboon/md@^0.1.0",
    "@std/front-matter": "jsr:@std/front-matter@^1",
    "@std/path": "jsr:@std/path@^1"
  },
  "fmt": {
    "exclude": ["dist", "node_modules", "static", "content"]
  },
  "lint": {
    "exclude": ["dist", "node_modules", "static/play"]
  }
}
